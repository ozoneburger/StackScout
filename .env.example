# Copy to .env locally. Do not commit real secrets.
PORT=4173
REFRESH_MS=86400000
ADMIN_TOKEN=[LONG_RANDOM_ADMIN_TOKEN]

# Required for Vercel Cron and manual cron endpoint calls.
# Vercel Cron sends Authorization: Bearer $CRON_SECRET to the configured path.
CRON_SECRET=[LONG_RANDOM_CRON_SECRET]

# Required in production on Vercel; optional for local development.
UPSTASH_REDIS_REST_URL=https://[UPSTASH_REDIS_ID].upstash.io
UPSTASH_REDIS_REST_TOKEN=[UPSTASH_REDIS_REST_TOKEN]

# Optional: enables product and price history writes on every refresh.
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=[SUPABASE_SERVICE_ROLE_KEY]

# Optional: enables npm run db:schema to apply supabase/schema.sql automatically.
# Find it in Supabase: Project Settings -> Database -> Connection string -> URI.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@[HOST]:6543/postgres
